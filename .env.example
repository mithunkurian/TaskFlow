# ============================================================
#  HomeAI — Smart Home Assistant Configuration
# ============================================================
#
#  STEP 1: Copy this file and rename it to ".env"
#          (the dot at the start is important!)
#
#  STEP 2: Replace "YOUR_KEY_HERE" with your actual API key
#          Get your key at: https://console.anthropic.com
#
#  STEP 3: Save the file, then run: npm start
# ============================================================

ANTHROPIC_API_KEY=YOUR_KEY_HERE

# Optional: change the port (default is 3000)
# PORT=3000
